{
  "expo": {
    "name": "Bucks Manager",
    "slug": "bucks-manager-android",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-bucks.png",
    "userInterfaceStyle": "dark",
    "scheme": "com.josev.bucksmanager",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.josev.bucksmanager"
    },
    "android": {
      "package": "com.josev.bucksmanager",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#050E0B",
        "foregroundImage": "./assets/android-icon-foreground-bucks.png",
        "backgroundImage": "./assets/android-icon-background-bucks.png",
        "monochromeImage": "./assets/android-icon-monochrome-bucks.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "com.josev.bucksmanager",
              "pathPrefix": "/oauthredirect"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon-bucks.png"
    },
    "plugins": [
      "@react-native-google-signin/google-signin",
      "expo-secure-store",
      "expo-sharing",
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "DMSans",
                "fontDefinitions": [
                  {
                    "path": "./node_modules/@expo-google-fonts/dm-sans/400Regular/DMSans_400Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./node_modules/@expo-google-fonts/dm-sans/500Medium/DMSans_500Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "./node_modules/@expo-google-fonts/dm-sans/600SemiBold/DMSans_600SemiBold.ttf",
                    "weight": 600
                  },
                  {
                    "path": "./node_modules/@expo-google-fonts/dm-sans/700Bold/DMSans_700Bold.ttf",
                    "weight": 700
                  }
                ]
              },
              {
                "fontFamily": "Inter",
                "fontDefinitions": [
                  {
                    "path": "./node_modules/@expo-google-fonts/inter/400Regular/Inter_400Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./node_modules/@expo-google-fonts/inter/500Medium/Inter_500Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "./node_modules/@expo-google-fonts/inter/600SemiBold/Inter_600SemiBold.ttf",
                    "weight": 600
                  },
                  {
                    "path": "./node_modules/@expo-google-fonts/inter/700Bold/Inter_700Bold.ttf",
                    "weight": 700
                  }
                ]
              },
              {
                "fontFamily": "InterVariable",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/InterVariable.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./assets/fonts/InterVariable-Italic.ttf",
                    "weight": 400,
                    "style": "italic"
                  }
                ]
              },
              {
                "fontFamily": "Fredoka",
                "fontDefinitions": [
                  {
                    "path": "./node_modules/@expo-google-fonts/fredoka/400Regular/Fredoka_400Regular.ttf",
                    "weight": 400
                  }
                ]
              },
              {
                "fontFamily": "JetBrainsMono",
