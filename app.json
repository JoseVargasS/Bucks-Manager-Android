                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/SFScribbledSans.ttf",
                    "weight": 700
                  }
                ]
              }
            ]
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-bucks.png",
          "resizeMode": "contain",
          "backgroundColor": "#050E0B"
        }
      ]
    ],
    "owner": "jose-vass"
  }
}
